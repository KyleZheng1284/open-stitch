# ─── Database ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=autovid_dev
DATABASE_URL=postgresql+asyncpg://autovid:autovid_dev@localhost:5432/autovid

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO / S3 ──────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ─── Sandbox ──────────────────────────────────────────────────────────
SANDBOX_IMAGE=autovid-sandbox:latest
SANDBOX_NETWORK=none
SANDBOX_CPU_LIMIT=4
SANDBOX_MEMORY_LIMIT=8g
SANDBOX_TIMEOUT_S=600

# ─── Model Endpoints ─────────────────────────────────────────────────
# ASR (Whisper)
ASR_MODEL=openai/whisper-large-v3-turbo
ASR_DEVICE=cuda:0

# VLM (Qwen3.5 primary)
VLM_ENDPOINT=http://localhost:8000/v1
VLM_MODEL=Qwen/Qwen3.5-397B-A17B-Instruct

# LLM (local)
LLM_ENDPOINT=http://localhost:8001/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
LLM_TEMPERATURE=0.4

# VLM Cloud (optional, disabled by default)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3-pro

# ─── Social OAuth ────────────────────────────────────────────────────
# YouTube
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=

# TikTok
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# Instagram
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=

# ─── Observability ───────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PORT=6006
