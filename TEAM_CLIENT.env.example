# Teammate config: call the host machine through Cloudflare

# LLM relay (OpenAI-compatible)
LLM_RELAY_BASE_URL=https://llm-relay.REPLACE_WITH_DOMAIN/v1
LLM_RELAY_API_KEY=replace-with-shared-relay-token

# Full Open-Stitch backend (optional, for upload/edit/render on host machine)
OPEN_STITCH_API_BASE_URL=https://open-stitch-api.REPLACE_WITH_DOMAIN
OPEN_STITCH_WS_BASE_URL=wss://open-stitch-api.REPLACE_WITH_DOMAIN

# Example endpoint paths
# Chat:        ${LLM_RELAY_BASE_URL}/chat/completions
# Health:      ${OPEN_STITCH_API_BASE_URL}/health
# Upload:      ${OPEN_STITCH_API_BASE_URL}/api/projects/upload
# Job stream:  ${OPEN_STITCH_WS_BASE_URL}/api/jobs/{project_id}/stream

